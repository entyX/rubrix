# ── Required ─────────────────────────────────────────────────────────────────
# The judge. Grading, Q&A generation, and rubric parsing run on Gemini.
GEMINI_API_KEY=

# ── Strongly recommended (DECISIONS D-018: open-source eyes and ears) ────────
# EARS — Whisper large-v3 on Groq (~$0.11 per audio HOUR; generous free tier).
# With this set, transcription stops using Gemini's 3.3x audio rate entirely and
# timestamps come from a real ASR system. Get a key: https://console.groq.com
GROQ_API_KEY=

# EYES — Qwen3-VL on OpenRouter (~1-2c per graded video run). With this set, the
# judge receives a visual-delivery report built from frames sampled across the
# WHOLE run instead of a handful of stills. Also the judge of last resort if the
# Gemini key runs out of quota/credit. Get a key: https://openrouter.ai
OPENROUTER_API_KEY=

# ── Optional overrides ───────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_VISION_MODEL=qwen/qwen3-vl-235b-a22b-instruct
# OPENROUTER_FALLBACK_MODEL=qwen/qwen3-vl-235b-a22b-instruct
# GROQ_WHISPER_MODEL=whisper-large-v3
# Set to "off" to hard-fail grading when Gemini is out of quota instead of
# rerouting the call to the open-source model on OpenRouter.
# RUBRIX_OSS_FALLBACK=off
# MAX_VIDEO_MIN=20
